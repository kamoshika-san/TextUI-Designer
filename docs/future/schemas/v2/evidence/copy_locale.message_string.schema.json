{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://textui-designer.dev/docs/future/schemas/v2/evidence/copy_locale.message_string.json",
  "title": "v2 evidence: copy_locale.message_string",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidence_shape", "before", "after"],
  "properties": {
    "evidence_shape": {
      "type": "string",
      "const": "copy_locale.message_string"
    },
    "before": { "$ref": "#/$defs/messageLeg" },
    "after": { "$ref": "#/$defs/messageLeg" }
  },
  "$defs": {
    "messageLeg": {
      "type": "object",
      "required": ["message_key", "locale", "text"],
      "properties": {
        "message_key": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 },
        "text": { "type": "string" },
        "plural_form": { "type": "string" },
        "note": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
