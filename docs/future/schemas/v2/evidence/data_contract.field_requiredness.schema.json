{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://textui-designer.dev/docs/future/schemas/v2/evidence/data_contract.field_requiredness.json",
  "title": "v2 evidence: data_contract.field_requiredness",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidence_shape", "before", "after"],
  "properties": {
    "evidence_shape": {
      "type": "string",
      "const": "data_contract.field_requiredness"
    },
    "before": { "$ref": "#/$defs/requirednessLeg" },
    "after": { "$ref": "#/$defs/requirednessLeg" }
  },
  "$defs": {
    "requirednessLeg": {
      "type": "object",
      "required": ["field_path", "required"],
      "properties": {
        "field_path": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "scope": { "type": "string" },
        "note": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
