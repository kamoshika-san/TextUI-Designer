{
  "name": "textui-designer",
  "displayName": "TextUI Designer",
  "description": "YAML/JSON DSLでUIを設計するVS Code拡張",
  "publisher": "kamoshika-san",
  "version": "0.9.3",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:textui-designer.openPreview",
    "onCommand:textui-designer.capturePreviewImage",
    "onCommand:textui-designer.export",
    "onCommand:textui-designer.checkAutoPreviewSetting",
    "onLanguage:yaml"
  ],
  "enabledApiProposals": [],
  "main": "./out/extension.js",
  "files": [
    "out/**/*",
    "node_modules/ajv/**/*",
    "node_modules/fast-deep-equal/**/*",
    "node_modules/fast-uri/**/*",
    "node_modules/json-schema-traverse/**/*",
    "node_modules/puppeteer-core/**/*",
    "node_modules/react/**/*",
    "node_modules/react-dom/**/*",
    "node_modules/require-from-string/**/*",
    "node_modules/yaml/**/*",
    "schemas/**/*",
    "media/**/*",
    "snippets/**/*",
    "icon.png",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "contributes": {
    "configuration": {
      "title": "TextUI Designer",
      "properties": {
        "textui-designer.supportedFileExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".tui.yml",
            ".tui.yaml"
          ],
          "description": "Choose which file extensions TextUI Designer treats as TextUI DSL files."
        },
        "textui-designer.autoPreview.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Open the Preview automatically when you open a TextUI file."
        },
        "textui-designer.devTools.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Allow the WebView developer tools command for troubleshooting extension internals."
        },
        "textui-designer.webview.disableThemeVariables": {
          "type": "boolean",
          "default": true,
          "description": "Use TextUI preview styling instead of inheriting VS Code theme variables."
        },
        "textui-designer.webview.theme": {
          "type": "string",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "default": "auto",
          "description": "Choose the Preview theme: follow VS Code, light, or dark."
        },
        "textui-designer.webview.fontSize": {
          "type": "number",
          "default": 14,
          "description": "Set the Preview font size in pixels."
        },
        "textui-designer.webview.jumpToDsl.showHoverIndicator": {
          "type": "boolean",
          "default": true,
          "description": "Show the hover hint for jumping from Preview components back to YAML."
        },
        "textui-designer.preview.showUpdateIndicator": {
          "type": "boolean",
          "default": true,
          "description": "Show a small status indicator when the Preview refreshes."
        },
        "textui-designer.export.defaultFormat": {
          "type": "string",
          "enum": [
            "html",
            "react",
            "svelte",
            "vue",
            "pug"
          ],
          "default": "html",
          "description": "Choose the export format used when no format is specified."
        },
        "textui-designer.export.includeComments": {
          "type": "boolean",
          "default": true,
          "description": "エクスポート時にコメントを含める"
        },
        "textui-designer.export.minify": {
          "type": "boolean",
          "default": false,
          "description": "エクスポート時にコードを圧縮"
        },
        "textui-designer.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show validation diagnostics for TextUI files."
        },
        "textui-designer.diagnostics.maxProblems": {
          "type": "number",
          "default": 100,
          "description": "最大診断問題数"
        },
        "textui-designer.diagnostics.validateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "保存時に診断を実行"
        },
        "textui-designer.diagnostics.validateOnChange": {
          "type": "boolean",
          "default": true,
          "description": "変更時に診断を実行"
        },
        "textui-designer.schema.validation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Validate TextUI files against the bundled schemas."
        },
        "textui-designer.schema.autoReload": {
          "type": "boolean",
          "default": true,
          "description": "スキーマの自動再読み込み"
        },
        "textui-designer.templates.defaultLocation": {
          "type": "string",
          "default": "",
          "description": "Default folder for saving templates"
        },
        "textui-designer.templates.customTemplates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "テンプレート名"
              },
              "path": {
                "type": "string",
                "description": "テンプレートファイルのパス"
              },
              "description": {
                "type": "string",
                "description": "テンプレートの説明"
              }
            },
            "required": [
              "name",
              "path"
            ]
          },
          "default": [],
          "description": "カスタムテンプレートの設定"
        },
        "textui-designer.performance.webviewDebounceDelay": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 2000,
          "description": "Delay Preview refreshes while typing, in milliseconds."
        },
        "textui-designer.performance.diagnosticDebounceDelay": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "maximum": 2000,
          "description": "診断のデバウンス時間（ミリ秒）"
        },
        "textui-designer.performance.completionDebounceDelay": {
          "type": "number",
          "default": 200,
          "minimum": 0,
          "maximum": 1000,
          "description": "補完のデバウンス時間（ミリ秒）"
        },
        "textui-designer.performance.cacheTTL": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "キャッシュの有効期限（ミリ秒）"
        },
        "textui-designer.performance.schemaCacheTTL": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "maximum": 300000,
          "description": "スキーマキャッシュの有効期限（ミリ秒）"
        },
        "textui-designer.performance.memoryMonitorInterval": {
          "type": "number",
          "default": 30000,
          "minimum": 10000,
          "maximum": 300000,
          "description": "メモリ使用量の監視間隔（ミリ秒、開発時のみ）"
        },
        "textui-designer.performance.enablePerformanceLogs": {
          "type": "boolean",
          "default": true,
          "description": "パフォーマンスログの有効化"
        },
        "textui-designer.performance.minUpdateInterval": {
          "type": "number",
          "default": 100,
          "minimum": 50,
          "maximum": 1000,
          "description": "最小更新間隔（ミリ秒）"
        },
        "textui-designer.performance.maxConcurrentOperations": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 5,
          "description": "最大同時処理数"
        },
        "textui-designer.performance.enableMemoryTracking": {
          "type": "boolean",
          "default": true,
          "description": "Track TextUI Designer memory usage for troubleshooting."
        },
        "textui-designer.performance.memoryMeasurementInterval": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "メモリ測定間隔（ミリ秒）"
        },
        "textui-designer.performance.memoryCleanupInterval": {
          "type": "number",
          "default": 30000,
          "minimum": 10000,
          "maximum": 300000,
          "description": "メモリクリーンアップ間隔（ミリ秒）"
        },
        "textui-designer.mcp.autoConfigure": {
          "type": "boolean",
          "default": true,
          "description": "拡張起動時にMCP設定を自動構成する（workspace: .vscode/mcp.json、user: ~/.config/.../mcp.json または .codex/config.toml の mcp_servers を更新）"
        },
        "textui-designer.mcp.scope": {
          "type": "string",
          "enum": [
            "workspace",
            "user",
            "both"
          ],
          "default": "both",
          "description": "Choose where TextUI Designer writes MCP client configuration."
        },
        "textui-designer.mcp.serverId": {
          "type": "string",
          "default": "textui-designer",
          "description": "mcp.jsonで使用するMCPサーバーID"
        },
        "textui-designer.mcp.command": {
          "type": "string",
          "default": "node",
          "description": "MCPサーバー起動コマンド（通常はnode）"
        },
        "textui-designer.mcp.notifyOnConfigured": {
          "type": "boolean",
          "default": true,
          "description": "MCP設定更新時に通知を表示する"
        }
      }
    },
    "commands": [
      {
        "command": "textui-designer.openPreview",
        "title": "TextUI: Preview Current File"
      },
      {
        "command": "textui-designer.openFlowPreview",
        "title": "TextUI: Preview Flow"
      },
      {
        "command": "textui-designer.capturePreviewImage",
        "title": "TextUI: Capture Preview Image"
      },
      {
        "command": "textui-designer.openDevTools",
        "title": "TextUI: Open Developer Tools"
      },
      {
        "command": "textui-designer.export",
        "title": "TextUI: Export Current File"
      },
      {
        "command": "textui-designer.export-preview",
        "title": "TextUI: Export Preview (Dry Run)"
      },
      {
        "command": "textui-designer.showJumpToDslHelp",
        "title": "TextUI: Preview to DSL Jump (How to Use)"
      },
      {
        "command": "textui-designer.openOverlayDiff",
        "title": "TextUI: Compare Files"
      },
      {
        "command": "textui-designer.createTemplate",
        "title": "TextUI: Create New Template"
      },
      {
        "command": "textui-designer.insertTemplate",
        "title": "TextUI: Insert Template"
      },
      {
        "command": "textui-designer.openSettings",
        "title": "TextUI: Open Settings"
      },
      {
        "command": "textui-designer.resetSettings",
        "title": "TextUI: Reset Settings"
      },
      {
        "command": "textui-designer.showSettings",
        "title": "TextUI: Show Settings"
      },
      {
        "command": "textui-designer.checkAutoPreviewSetting",
        "title": "TextUI: Check Auto Preview Setting"
      },
      {
        "command": "textui-designer.reinitializeSchemas",
        "title": "TextUI: Reinitialize Schemas"
      },
      {
        "command": "textui-designer.debugSchemas",
        "title": "TextUI: Debug Schema State"
      },
      {
        "command": "textui-designer.showPerformanceReport",
        "title": "TextUI: Show Performance Report"
      },
      {
        "command": "textui-designer.clearPerformanceMetrics",
        "title": "TextUI: Clear Performance Metrics"
      },
      {
        "command": "textui-designer.togglePerformanceMonitoring",
        "title": "TextUI: Toggle Performance Monitoring"
      },
      {
        "command": "textui-designer.enablePerformanceMonitoring",
        "title": "TextUI: Enable Performance Monitoring"
      },
      {
        "command": "textui-designer.generateSampleEvents",
        "title": "TextUI: Generate Sample Events"
      },
      {
        "command": "textui-designer.showMemoryReport",
        "title": "TextUI: Show Memory Report"
      },
      {
        "command": "textui-designer.toggleMemoryTracking",
        "title": "TextUI: Toggle Memory Tracking"
      },
      {
        "command": "textui-designer.enableMemoryTracking",
        "title": "TextUI: Enable Memory Tracking"
      }
    ],
    "walkthroughs": [
      {
        "id": "textui-designer.gettingStarted",
        "title": "Get started with TextUI Designer",
        "description": "Create a TextUI screen, preview it, edit it live, inspect export output, and open a flow preview without leaving VS Code.",
        "steps": [
          {
            "id": "create-sample-tui",
            "title": "Create a sample .tui.yml file",
            "description": "Create a file named `hello.tui.yml` and paste the minimal sample from the README or `sample/01-basic/sample.tui.yml`. Success: the file is saved with a `page` block and at least one component."
          },
          {
            "id": "open-preview",
            "title": "Open Preview",
            "description": "Run [TextUI: Preview Current File](command:textui-designer.openPreview) while the `.tui.yml` file is active. Success: a side panel renders the current screen.",
            "completionEvents": [
              "onCommand:textui-designer.openPreview"
            ]
          },
          {
            "id": "edit-live-preview",
            "title": "Edit and watch the Preview update",
            "description": "Change text or a button label in the YAML file, then save or let auto preview refresh. Success: the Preview reflects the edit and the update indicator appears when enabled."
          },
          {
            "id": "open-export-preview",
            "title": "Inspect Export Preview",
            "description": "Run [TextUI: Export Preview (Dry Run)](command:textui-designer.export-preview) to inspect generated code before writing files. Success: generated output is shown without changing project files.",
            "completionEvents": [
              "onCommand:textui-designer.export-preview"
            ]
          },
          {
            "id": "open-flow-preview",
            "title": "Open Flow Preview",
            "description": "Open `sample/12-navigation/app.tui.flow.yml`, then run [TextUI: Preview Flow](command:textui-designer.openFlowPreview). Success: the flow map opens and linked screens can be inspected.",
            "completionEvents": [
              "onCommand:textui-designer.openFlowPreview"
            ]
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "yaml",
        "extensions": [
          ".tui.flow.yml",
          ".tui.flow.yaml"
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "textui-designer.openPreview",
          "when": "resourceLangId == yaml || resourceFilename =~ /\\.tui\\./",
          "group": "navigation"
        },
        {
          "command": "textui-designer.export",
          "when": "resourceLangId == yaml || resourceFilename =~ /\\.tui\\./",
          "group": "navigation"
        },
        {
          "command": "textui-designer.openOverlayDiff",
          "when": "resourceLangId == yaml || resourceFilename =~ /\\.tui\\./",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "textui-designer.openDevTools",
          "when": "false"
        },
        {
          "command": "textui-designer.debugSchemas",
          "when": "false"
        },
        {
          "command": "textui-designer.showPerformanceReport",
          "when": "false"
        },
        {
          "command": "textui-designer.clearPerformanceMetrics",
          "when": "false"
        },
        {
          "command": "textui-designer.togglePerformanceMonitoring",
          "when": "false"
        },
        {
          "command": "textui-designer.enablePerformanceMonitoring",
          "when": "false"
        },
        {
          "command": "textui-designer.generateSampleEvents",
          "when": "false"
        },
        {
          "command": "textui-designer.showMemoryReport",
          "when": "false"
        },
        {
          "command": "textui-designer.toggleMemoryTracking",
          "when": "false"
        },
        {
          "command": "textui-designer.enableMemoryTracking",
          "when": "false"
        }
      ]
    },
    "snippets": [
      {
        "language": "yaml",
        "path": "./snippets/tui-snippets.json"
      },
      {
        "language": "json",
        "path": "./snippets/tui-snippets.json"
      }
    ],
    "yaml.schemas": {
      "./schemas/schema.json": [
        "*.tui.yml",
        "*.tui.yaml"
      ],
      "./schemas/navigation-schema.json": [
        "*.tui.flow.yml",
        "*.tui.flow.yaml"
      ],
      "./schemas/template-schema.json": [
        "*.template.yml",
        "*.template.yaml"
      ],
      "./schemas/theme-schema.json": [
        "*-theme.yml",
        "*-theme.yaml",
        "*_theme.yml",
        "*_theme.yaml",
        "textui-theme.yml",
        "textui-theme.yaml"
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": "*.tui.flow.json",
        "url": "./schemas/navigation-schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run package && npm run build-webview",
    "compile": "tsc -p ./ && node ./scripts/generate-schemas-from-definitions.cjs && node ./scripts/check-generated-schema-chain.cjs",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "webpack --mode production --devtool hidden-source-map",
    "package:vsix": "npm run compile && npm run package && npm run build-webview && npx --yes @vscode/vsce package",
    "build-webview": "node ./scripts/generate-renderer-index-css.cjs && vite build",
    "dev-webview": "node ./scripts/generate-renderer-index-css.cjs && vite",
    "validate:samples": "node ./scripts/validate-samples.cjs",
    "validate:samples:navigation": "npm run compile && node ./scripts/validate-samples.cjs",
    "validate:samples:fresh": "npm run compile && npm run validate:samples",
    "validate:samples:compiled": "npm run validate:samples",
    "check:schema-generation": "node ./scripts/check-generated-schema-chain.cjs",
    "metrics:collect": "node ./scripts/collect-code-metrics.cjs",
    "metrics:check:ssot": "node ./scripts/check-ssot-regression-metrics.cjs",
    "check:dsl-types-ssot": "node ./scripts/check-dsl-type-imports.cjs",
    "check:html-exporter-fallback-lane": "node ./scripts/check-html-exporter-fallback-lane-contract.cjs",
    "check:webview-media-drift": "node ./scripts/check-webview-media-drift.cjs",
    "check:import-graph": "node ./scripts/check-import-graph-boundaries.cjs",
    "check:undeclared-requires": "node ./scripts/check-undeclared-requires.cjs",
    "check:ssot:non-renderer": "mocha --no-config --require ./tests/setup.js --timeout 5000 --exit tests/unit/non-renderer-ssot-meta-guard.test.js",
    "check:ssot:exporters": "mocha --no-config --require ./tests/setup.js --timeout 5000 --exit tests/unit/exporters-ssot-import-guard.test.js tests/unit/exporter-common-foundation-ssot-guard.test.js tests/unit/react-exporter-wave-ssot-guard.test.js tests/unit/exporter-format-wave-ssot-guard.test.js tests/unit/html-renderers-exporter-ssot-guard.test.js tests/unit/exporter-ssot-guard-coverage.test.js",
    "react-ssot-check": "mocha --no-config --require ./tests/setup.js --timeout 5000 --exit tests/unit/shared-kernel-preview-export-parity.test.js tests/unit/react-theme-vars-preview-export-contract.test.js",
    "report:react-fallback-usage": "node ./scripts/report-react-fallback-usage.cjs",
    "plan:pr": "node ./scripts/plan-pr-diff.cjs",
    "sync:configuration": "npm run compile && node ./scripts/generate-contributes-configuration.cjs",
    "check:configuration": "npm run compile && node ./scripts/check-contributes-configuration.cjs",
    "sync:commands": "npm run compile && node ./scripts/sync-command-manifest.cjs",
    "check:commands": "npm run compile && node ./scripts/check-command-manifest.cjs",
    "check:contributes": "npm run compile && node ./scripts/check-contributes-integrity.cjs",
    "sync:package-contributes": "node ./scripts/merge-package-contributes.cjs",
    "inspect:contributes": "node ./scripts/inspect-contributes.cjs",
    "inspect:contributes:markdown": "node ./scripts/inspect-contributes.cjs --markdown",
    "diff:contributes:fragments": "node ./scripts/diff-contributes-fragments.cjs",
    "diff:contributes:fragments:markdown": "node ./scripts/diff-contributes-fragments.cjs --markdown",
    "contributes:pr-summary": "node ./scripts/contributes-pr-summary.cjs",
    "docs:package-contributes": "node ./scripts/generate-package-contributes-docs.cjs",
    "compile-tests": "npm run compile",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run pretest:ci",
    "typecheck:strict": "tsc -p ./ --noEmit",
    "typecheck:strict:warn": "npm run typecheck:strict || true",
    "pretest:ci": "npm run compile && npm run typecheck:strict && npm run lint && npm run check:html-exporter-fallback-lane",
    "pretest:local": "npm run compile",
    "lint": "eslint src --max-warnings 0 && eslint tests/unit/html-exporter-route-viability.test.js tests/unit/html-exporter-fallback-style-lane.test.js --max-warnings 0",
    "format:check": "npm run lint",
    "test": "mocha --no-config --require ./tests/setup.js --timeout 5000 --exit \"tests/unit/**/*.js\"",
    "vscode-test": "node ./out/test/runTest.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov --reporter=json-summary npm run test:unit",
    "test:regression": "mocha --no-config --require ./tests/setup.js --timeout 20000 --exit ./tests/regression/export-regression-suite.js ./tests/regression/export-from-preview.test.js ./tests/regression/navigation-export-regression.test.js",
    "test:unit": "mocha --no-config --require ./tests/setup.js --timeout 5000 --exit \"tests/unit/**/*.js\"",
    "test:mcp": "mocha --no-config --require ./tests/setup.js --timeout 20000 --exit tests/unit/mcp-params.test.js tests/unit/mcp-request-handlers.test.js tests/unit/mcp-server.test.js tests/unit/mcp-flow.test.js tests/unit/mcp-bootstrap-service.test.js",
    "test:integration": "mocha --no-config --require ./tests/setup.js --timeout 20000 --exit ./tests/integration/command-manager.test.js ./tests/integration/theme-switching.test.js ./tests/integration/navigation-engine.test.js",
    "test:e2e": "mocha --no-config --require ./tests/setup.js --timeout 20000 --exit ./tests/e2e/export-from-preview-e2e.test.js",
    "test:vscode-smoke": "node ./tests/vscode-smoke/runTest.js",
    "test:quick": "npm run pretest:local && npm run test:unit",
    "test:all": "npm run pretest:local && npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:regression",
    "test:all:ci:base": "npm run pretest:ci && npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:regression",
    "test:navigation-coverage:gate": "node ./scripts/check-navigation-coverage.cjs",
    "test:all:ci": "c8 --reporter=text --reporter=lcov --reporter=json-summary npm run test:all:ci:base && npm run test:cli-coverage:gate && npm run test:navigation-coverage:gate && npm run check:import-graph",
    "test:cli-coverage:gate": "node ./scripts/check-cli-coverage.cjs",
    "cli": "node ./out/cli/index.js",
    "mcp:serve": "node ./out/mcp/server.js",
    "prepare": "node ./scripts/prepare.cjs",
    "precli": "npm run compile",
    "generate:diff-traceability": "node scripts/generate-diff-traceability.cjs",
    "test:diff-coverage-guard": "node scripts/check-diff-coverage.cjs",
    "diff:smoke:local": "node scripts/diff-smoke.cjs --axis=local-only",
    "diff:smoke:ci": "node scripts/diff-smoke.cjs --axis=ci-only",
    "diff:smoke:pr": "node scripts/diff-smoke.cjs --axis=pr-enabled --dry-run",
    "diff:matrix:delta": "ts-node scripts/diff-matrix-delta.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@types/react": "^18.2.0",
