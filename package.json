{
  "name": "textui-designer",
  "displayName": "TextUI Designer",
  "description": "YAML/JSON DSLでUIを設計するVS Code拡張",
  "publisher": "kamoshika-san",
  "version": "0.5.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:textui-designer.openPreview",
    "onCommand:textui-designer.capturePreviewImage",
    "onCommand:textui-designer.export",
    "onCommand:textui-designer.checkAutoPreviewSetting",
    "onLanguage:yaml"
  ],
  "enabledApiProposals": [],
  "main": "./out/extension.js",
  "files": [
    "out/**/*",
    "node_modules/ajv/**/*",
    "node_modules/fast-deep-equal/**/*",
    "node_modules/fast-uri/**/*",
    "node_modules/json-schema-traverse/**/*",
    "node_modules/puppeteer-core/**/*",
    "node_modules/require-from-string/**/*",
    "node_modules/yaml/**/*",
    "schemas/**/*",
    "media/**/*",
    "snippets/**/*",
    "icon.png",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "contributes": {
    "configuration": {
      "title": "TextUI Designer",
      "properties": {
        "textui-designer.supportedFileExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".tui.yml",
            ".tui.yaml"
          ],
          "description": "サポートするファイル拡張子"
        },
        "textui-designer.autoPreview.enabled": {
          "type": "boolean",
          "default": false,
          "description": "ファイルを開いた時に自動的にプレビューを表示"
        },
        "textui-designer.devTools.enabled": {
          "type": "boolean",
          "default": false,
          "description": "開発者ツールの有効化"
        },
        "textui-designer.webview.disableThemeVariables": {
          "type": "boolean",
          "default": true,
          "description": "VS Codeのテーマ変数を無効化して独自スタイルを使用"
        },
        "textui-designer.webview.theme": {
          "type": "string",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "default": "auto",
          "description": "WebViewのテーマ"
        },
        "textui-designer.webview.fontSize": {
          "type": "number",
          "default": 14,
          "description": "WebViewのフォントサイズ"
        },
        "textui-designer.export.defaultFormat": {
          "type": "string",
          "enum": [
            "html",
            "react",
            "pug"
          ],
          "default": "html",
          "description": "デフォルトのエクスポート形式"
        },
        "textui-designer.export.includeComments": {
          "type": "boolean",
          "default": true,
          "description": "エクスポート時にコメントを含める"
        },
        "textui-designer.export.minify": {
          "type": "boolean",
          "default": false,
          "description": "エクスポート時にコードを圧縮"
        },
        "textui-designer.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "診断機能の有効化"
        },
        "textui-designer.diagnostics.maxProblems": {
          "type": "number",
          "default": 100,
          "description": "最大診断問題数"
        },
        "textui-designer.diagnostics.validateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "保存時に診断を実行"
        },
        "textui-designer.diagnostics.validateOnChange": {
          "type": "boolean",
          "default": true,
          "description": "変更時に診断を実行"
        },
        "textui-designer.schema.validation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "スキーマ検証の有効化"
        },
        "textui-designer.schema.autoReload": {
          "type": "boolean",
          "default": true,
          "description": "スキーマの自動再読み込み"
        },
        "textui-designer.templates.defaultLocation": {
          "type": "string",
          "default": "",
          "description": "テンプレートのデフォルト保存場所"
        },
        "textui-designer.templates.customTemplates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "テンプレート名"
              },
              "path": {
                "type": "string",
                "description": "テンプレートファイルのパス"
              },
              "description": {
                "type": "string",
                "description": "テンプレートの説明"
              }
            },
            "required": [
              "name",
              "path"
            ]
          },
          "default": [],
          "description": "カスタムテンプレートの設定"
        },
        "textui-designer.performance.webviewDebounceDelay": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 2000,
          "description": "WebView更新のデバウンス時間（ミリ秒）"
        },
        "textui-designer.performance.diagnosticDebounceDelay": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "maximum": 2000,
          "description": "診断のデバウンス時間（ミリ秒）"
        },
        "textui-designer.performance.completionDebounceDelay": {
          "type": "number",
          "default": 200,
          "minimum": 0,
          "maximum": 1000,
          "description": "補完のデバウンス時間（ミリ秒）"
        },
        "textui-designer.performance.cacheTTL": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "キャッシュの有効期限（ミリ秒）"
        },
        "textui-designer.performance.schemaCacheTTL": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "maximum": 300000,
          "description": "スキーマキャッシュの有効期限（ミリ秒）"
        },
        "textui-designer.performance.memoryMonitorInterval": {
          "type": "number",
          "default": 30000,
          "minimum": 10000,
          "maximum": 300000,
          "description": "メモリ使用量の監視間隔（ミリ秒、開発時のみ）"
        },
        "textui-designer.performance.enablePerformanceLogs": {
          "type": "boolean",
          "default": true,
          "description": "パフォーマンスログの有効化"
        },
        "textui-designer.performance.minUpdateInterval": {
          "type": "number",
          "default": 100,
          "minimum": 50,
          "maximum": 1000,
          "description": "最小更新間隔（ミリ秒）"
        },
        "textui-designer.performance.maxConcurrentOperations": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 5,
          "description": "最大同時処理数"
        },
        "textui-designer.performance.enableMemoryTracking": {
          "type": "boolean",
          "default": false,
          "description": "TextUI Designer専用のメモリ追跡を有効化"
        },
        "textui-designer.performance.memoryMeasurementInterval": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "メモリ測定間隔（ミリ秒）"
        },
        "textui-designer.performance.memoryCleanupInterval": {
          "type": "number",
          "default": 30000,
          "minimum": 10000,
          "maximum": 300000,
          "description": "メモリクリーンアップ間隔（ミリ秒）"
        },
        "textui-designer.mcp.autoConfigure": {
          "type": "boolean",
          "default": true,
          "description": "拡張起動時にMCP設定(mcp.json)を自動構成する"
        },
        "textui-designer.mcp.scope": {
          "type": "string",
          "enum": [
            "workspace",
            "user",
            "both"
          ],
          "default": "both",
          "description": "MCP設定の書き込み先（mcp.json と Codex用 .codex/config.toml）"
        },
        "textui-designer.mcp.serverId": {
          "type": "string",
          "default": "textui-designer",
          "description": "mcp.jsonで使用するMCPサーバーID"
        },
        "textui-designer.mcp.command": {
          "type": "string",
          "default": "node",
          "description": "MCPサーバー起動コマンド（通常はnode）"
        },
        "textui-designer.mcp.notifyOnConfigured": {
          "type": "boolean",
          "default": true,
          "description": "MCP設定更新時に通知を表示する"
        }
      }
    },
    "commands": [
      {
        "command": "textui-designer.openPreview",
        "title": "TextUI: Open Preview"
      },
      {
        "command": "textui-designer.capturePreviewImage",
        "title": "TextUI: Capture Preview Image"
      },
      {
        "command": "textui-designer.openDevTools",
        "title": "TextUI: Open Developer Tools"
      },
      {
        "command": "textui-designer.export",
        "title": "TextUI: Export to Code"
      },
      {
        "command": "textui-designer.createTemplate",
        "title": "TextUI: 新規テンプレート作成"
      },
      {
        "command": "textui-designer.insertTemplate",
        "title": "TextUI: テンプレート挿入"
      },
      {
        "command": "textui-designer.openSettings",
        "title": "TextUI: 設定を開く"
      },
      {
        "command": "textui-designer.resetSettings",
        "title": "TextUI: 設定をリセット"
      },
      {
        "command": "textui-designer.showSettings",
        "title": "TextUI: 設定を表示"
      },
      {
        "command": "textui-designer.checkAutoPreviewSetting",
        "title": "TextUI: 自動プレビュー設定を確認"
      },
      {
        "command": "textui-designer.reinitializeSchemas",
        "title": "TextUI: スキーマを再初期化"
      },
      {
        "command": "textui-designer.debugSchemas",
        "title": "TextUI: スキーマ状態をデバッグ"
      },
      {
        "command": "textui-designer.showPerformanceReport",
        "title": "TextUI: パフォーマンスレポートを表示"
      },
      {
        "command": "textui-designer.clearPerformanceMetrics",
        "title": "TextUI: パフォーマンスメトリクスをクリア"
      },
      {
        "command": "textui-designer.togglePerformanceMonitoring",
        "title": "TextUI: パフォーマンス監視の切り替え"
      },
      {
        "command": "textui-designer.enablePerformanceMonitoring",
        "title": "TextUI: パフォーマンス監視を有効化"
      },
      {
        "command": "textui-designer.generateSampleEvents",
        "title": "TextUI: サンプルイベントを生成"
      },
      {
        "command": "textui-designer.showMemoryReport",
        "title": "TextUI: メモリレポートを表示"
      },
      {
        "command": "textui-designer.toggleMemoryTracking",
        "title": "TextUI: メモリ追跡の切り替え"
      },
      {
        "command": "textui-designer.enableMemoryTracking",
        "title": "TextUI: メモリ追跡を有効化"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "textui-designer.openPreview",
          "when": "resourceLangId == yaml",
          "group": "navigation"
        },
        {
          "command": "textui-designer.export",
          "when": "resourceLangId == yaml",
          "group": "navigation"
        }
      ]
    },
    "snippets": [
      {
        "language": "yaml",
        "path": "./snippets/tui-snippets.json"
      },
      {
        "language": "json",
        "path": "./snippets/tui-snippets.json"
      }
    ],
    "yaml.schemas": {
      "./schemas/schema.json": [
        "*.tui.yml",
        "*.tui.yaml"
      ],
      "./schemas/template-schema.json": [
        "*.template.yml",
        "*.template.yaml"
      ],
      "./schemas/theme-schema.json": [
        "*-theme.yml",
        "*-theme.yaml",
        "*_theme.yml",
        "*_theme.yaml",
        "textui-theme.yml",
        "textui-theme.yaml"
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run package && npm run build-webview",
    "compile": "tsc -p ./",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "webpack --mode production --devtool hidden-source-map",
    "package:vsix": "npm run compile && npm run package && npm run build-webview && npx --yes @vscode/vsce package",
    "build-webview": "vite build",
    "dev-webview": "vite",
    "validate:samples": "node ./scripts/validate-samples.cjs",
    "validate:samples:fresh": "npm run compile && npm run validate:samples",
    "validate:samples:compiled": "npm run validate:samples",
    "plan:pr": "node ./scripts/plan-pr-diff.cjs",
    "sync:commands": "npm run compile && node ./scripts/sync-command-manifest.cjs",
    "check:commands": "npm run compile && node ./scripts/check-command-manifest.cjs",
    "compile-tests": "npm run compile",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run pretest:ci",
    "typecheck:strict": "tsc -p ./ --noEmit",
    "typecheck:strict:warn": "npm run typecheck:strict || true",
    "pretest:ci": "npm run compile && npm run typecheck:strict && npm run lint",
    "pretest:local": "npm run compile",
    "lint": "eslint src --max-warnings 0",
    "format:check": "npm run lint",
    "test": "mocha --no-config --require ./tests/setup.js --timeout 5000 --exit tests/unit/**/*.js",
    "vscode-test": "node ./out/test/runTest.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov npm run test:unit",
    "test:regression": "mocha --no-config --require ./tests/setup.js --timeout 20000 --exit ./tests/regression/export-regression-suite.js",
    "test:unit": "mocha --no-config --require ./tests/setup.js --timeout 5000 --exit tests/unit/**/*.js",
    "test:integration": "mocha --no-config --require ./tests/setup.js --timeout 5000 --exit ./tests/integration/command-manager.test.js",
    "test:e2e": "mocha --no-config --require ./tests/setup.js --timeout 20000 --exit ./tests/e2e/export-from-preview-e2e.test.js",
    "test:quick": "npm run pretest:local && npm run test:unit",
    "test:all": "npm run pretest:local && npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:regression",
    "test:all:ci": "npm run pretest:ci && npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:regression",
    "cli": "node ./out/cli/index.js",
    "mcp:serve": "node ./out/mcp/server.js",
    "prepare": "node ./scripts/prepare.cjs",
    "precli": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vscode/test-electron": "^2.3.8",
    "c8": "^11.0.0",
    "chai": "^4.3.10",
    "chai-as-promised": "^8.0.1",
    "eslint": "^8.56.0",
    "glob": "^10.5.0",
    "mocha": "^10.2.0",
    "sinon": "^21.0.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^6.4.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "ajv": "^8.18.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "puppeteer-core": "^24.39.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "yaml": "^2.3.0"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamoshika-san/TextUI-Designer.git"
  },
  "bin": {
    "textui": "./out/cli/index.js"
  },
  "overrides": {
    "serialize-javascript": "7.0.3"
  }
}
