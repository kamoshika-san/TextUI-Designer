{
  "yaml.schemas": {
    "./schemas/schema.json": [
      "*.tui.yml",
      "*.tui.yaml"
    ],
    "./schemas/navigation-schema.json": [
      "*.tui.flow.yml",
      "*.tui.flow.yaml"
    ],
    "./schemas/template-schema.json": [
      "*.template.yml",
      "*.template.yaml"
    ],
    "./schemas/theme-schema.json": [
      "*-theme.yml",
      "*-theme.yaml",
      "*_theme.yml",
      "*_theme.yaml",
      "textui-theme.yml",
      "textui-theme.yaml"
    ]
  },
  "jsonValidation": [
    {
      "fileMatch": "*.tui.flow.json",
      "url": "./schemas/navigation-schema.json"
    }
  ]
}
